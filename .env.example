# ─── IMAP ACCOUNTS ────────────────────────────────────────────────────────────
# Accounts are configured in config.yaml (copy config.example.yaml to config.yaml
# and fill in your credentials). This file only controls global settings.

# ─── WEB UI AUTH ──────────────────────────────────────────────────────────────
MAILHOOK_ADMIN_USER=admin
# Generate with: htpasswd -bnBC 12 "" yourpassword | tr -d ':\n' | sed 's/$2y/$2a/'
MAILHOOK_ADMIN_PASSWORD_BCRYPT=$2a$12$changeme...

# ─── REQUIRED SECRETS ─────────────────────────────────────────────────────────
# Rotate commands (run these and paste output below):
#   CSRF secret:        openssl rand -hex 32
#   DB encryption key:  openssl rand -hex 32
#   Admin password:     htpasswd -nbBC 12 admin NEWPASSWORD | cut -d: -f2
# After rotating, verify the suffix shown in the startup log ("secrets loaded") changed.
MAILHOOK_CSRF_SECRET=changeme-generate-with-openssl-rand-hex-32
# Encrypts IMAP passwords and API keys in the database.
MAILHOOK_DB_ENCRYPTION_KEY=changeme-generate-with-openssl-rand-hex-32

# ─── SCANNERS ─────────────────────────────────────────────────────────────────
MAILHOOK_RSPAMD_URL=http://rspamd:11333
MAILHOOK_CLAMAV_ADDR=clamav:3310
MAILHOOK_YARA_RULES_DIR=/rules

# ─── VERDICT THRESHOLDS ───────────────────────────────────────────────────────
MAILHOOK_SPAM_SCORE=5.0
MAILHOOK_REJECT_SCORE=15.0

# ─── COOKIES / HTTP vs HTTPS ──────────────────────────────────────────────────
# Session cookies carry the Secure flag by default so they are only sent over
# HTTPS. If you are accessing MailHook over plain HTTP from a non-localhost
# address (e.g. a LAN host or Docker on a non-loopback IP), you must set this
# to true or login will silently fail (the browser drops the Secure cookie).
# Leave false (default) when you are behind a TLS-terminating reverse proxy.
MAILHOOK_INSECURE_COOKIES=false

# ─── OPTIONAL EXTERNAL APIs ───────────────────────────────────────────────────
# Leave empty to disable the scanner
MAILHOOK_ABUSEIPDB_KEY=
MAILHOOK_VT_API_KEY=
# PhishTank application key — optional but recommended (avoids rate limits).
# Register at https://www.phishtank.com/api_info.php for a free key.
MAILHOOK_PHISHTANK_KEY=

# ─── STORAGE ──────────────────────────────────────────────────────────────────
MAILHOOK_DATA_DIR=/data
MAILHOOK_FEEDS_CACHE_DIR=/feeds-cache
MAILHOOK_DB_PATH=/data/mailhook.db
MAILHOOK_RETENTION_DAYS=30

# ─── NOTIFICATIONS (ntfy) ─────────────────────────────────────────────────────
# Leave MAILHOOK_NTFY_URL empty to disable notifications.
# WARNING: do NOT use a public ntfy.sh topic — email metadata (From, Subject) will
# be visible to anyone who subscribes. Use a self-hosted ntfy server or a private
# topic protected with MAILHOOK_NTFY_TOKEN.
MAILHOOK_NTFY_URL=
MAILHOOK_NTFY_TOPIC=mailhook
# Optional: Bearer token for authenticated ntfy topics
MAILHOOK_NTFY_TOKEN=
# Mask From address and Subject in ntfy/webhook payloads to avoid leaking
# email metadata to external notification services. Recommended: true.
MAILHOOK_REDACT_WEBHOOK_PII=true

# ─── METRICS ──────────────────────────────────────────────────────────────────
# Comma-separated CIDRs allowed to access /metrics (Prometheus scraping)
# Default: loopback only — opt in to wider ranges if needed (e.g. 127.0.0.1/32,10.0.0.0/8)
# WARNING: /metrics and /api/scan are unauthenticated — do NOT expose to untrusted clients.
MAILHOOK_METRICS_ALLOWED_CIDRS=127.0.0.1/32,::1/128

# ─── TIMING ───────────────────────────────────────────────────────────────────
MAILHOOK_SCAN_TIMEOUT=60s
MAILHOOK_FEED_REFRESH_INTERVAL=6h
MAILHOOK_IMAP_RECONNECT_MAX=5m

# ─── LOGGING ──────────────────────────────────────────────────────────────────
MAILHOOK_LOG_LEVEL=info
MAILHOOK_LOG_FORMAT=json
