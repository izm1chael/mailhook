# AI-enabled build: ONNX Runtime + DistilBERT + DGA CNN baked into the binary.
# Models are embedded via //go:embed — run 'make models-dl && make models-bert'
# on the host before building so the model files exist in scanners/models/.
# Memory budget: ~265MB additional RSS vs standard build when models are loaded.
# Build with: docker compose -f docker-compose.yml -f docker-compose.ai.yml build

FROM golang:1.26.3-bookworm@sha256:386d475a660466863d9f8c766fec64d7fdad3edac2c6a05020c09534d71edb4b AS builder

ARG YARA_VERSION=4.5.2
# onnxruntime_go v1.30.1 requires ONNX Runtime C library v1.25.0
ARG ONNX_VERSION=1.25.0

RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        gcc \
        make \
        automake \
        autoconf \
        libtool \
        libssl-dev \
        libmagic-dev \
        libjansson-dev \
        pkg-config \
        ca-certificates \
        wget \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Compile YARA from source (Debian 12 repo only has 4.2.3).
RUN set -eux; \
    cd /tmp; \
    wget -qO yara.tar.gz \
      "https://github.com/VirusTotal/yara/archive/refs/tags/v${YARA_VERSION}.tar.gz"; \
    tar -xzf yara.tar.gz; \
    cd "yara-${YARA_VERSION}"; \
    autoreconf -fiv; \
    ./configure \
        --enable-magic \
        --with-crypto \
        --disable-shared \
        --enable-static \
        --prefix=/usr/local; \
    make -j"$(nproc)"; \
    make install; \
    rm -rf /tmp/yara*

# Download ONNX Runtime shared library for the target architecture.
RUN set -eux; \
    ARCH="$(uname -m)"; \
    case "$ARCH" in \
      x86_64)  ORT_ARCH=x64 ;; \
      aarch64) ORT_ARCH=aarch64 ;; \
      *) echo "Unsupported arch: $ARCH" && exit 1 ;; \
    esac; \
    curl -fsSL \
      "https://github.com/microsoft/onnxruntime/releases/download/v${ONNX_VERSION}/onnxruntime-linux-${ORT_ARCH}-${ONNX_VERSION}.tgz" \
      | tar xz --strip-components=1 -C /usr/local

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

# Copy source — model files in scanners/models/ are embedded by //go:embed.
# Ensure 'make models-dl && make models-bert' have been run before docker build.
COPY . .

ARG VERSION=dev
RUN PKG_CONFIG_PATH=/usr/local/lib/pkgconfig \
    CGO_ENABLED=1 GOOS=linux \
    CGO_CFLAGS="-I/usr/local/include/onnxruntime" \
    CGO_LDFLAGS="-L/usr/local/lib -lonnxruntime" \
    go build \
    -tags "yara_static ai" \
    -trimpath \
    "-ldflags=-s -w -X main.version=${VERSION}" \
    -o /out/mailhook-ai \
    .

# ── Runtime ────────────────────────────────────────────────────────────────────
# Models are inside the binary — no model volume needed.
FROM debian:12-slim@sha256:0104b334637a5f19aa9c983a91b54c89887c0984081f2068983107a6f6c21eeb

RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        libmagic1 \
        libssl3 \
        ca-certificates \
        tzdata \
        wget \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd -r -g 1000 mailhook \
    && useradd -r -u 1000 -g mailhook --no-create-home --shell /usr/sbin/nologin mailhook \
    && install -d -o mailhook -g mailhook -m 750 \
        /data /data/emls \
        /feeds-cache \
        /rules

# ONNX Runtime shared library (the only runtime dependency not in the binary)
COPY --from=builder /usr/local/lib/libonnxruntime.so* /usr/local/lib/
RUN echo "/usr/local/lib" > /etc/ld.so.conf.d/onnxruntime.conf && ldconfig && ln -sf /usr/local/lib/libonnxruntime.so /usr/local/lib/onnxruntime.so

COPY --from=builder /out/mailhook-ai /usr/local/bin/mailhook
ENV LD_LIBRARY_PATH=/usr/local/lib

VOLUME ["/data", "/feeds-cache", "/rules"]

USER mailhook
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD wget -qO- http://localhost:8080/healthz || exit 1

ENTRYPOINT ["/usr/local/bin/mailhook"]
